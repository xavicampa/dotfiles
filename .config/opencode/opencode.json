    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3-4b-2507": {},
        "qwen/qwen3-4b-thinking-2507": {},
        "openai/gpt-oss-20b": {},
        "rnj-1-instruct-mlx": {}
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "unsloth/Qwen3.6-35B-A3B-GGUF": {
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    },
    "tensorrt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "TensorRT",
      "options": {
        "baseURL": "http://homepc:8000/v1"
      },
      "models": {
        "nvidia/Qwen3-8B-NVFP4": {
          "limit": {
            "context": 40000,
            "output": 8000
          }
        },
      }
    }
  },
  "mcp": {
    "brave-mcp": {
      "enabled": false,
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "BRAVE_API_KEY",
        "docker.io/mcp/brave-search"
      ]
    },
    "aws-docs-mcp": {
      "enabled": false,
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "FASTMCP_LOG_LEVEL=ERROR",
        "-e",
        "AWS_DOCUMENTATION_PARTITION=aws",
        "public.ecr.aws/awslabs-mcp/awslabs/aws-documentation-mcp-server:latest"
      ],
      "environment": {}
    },
    "aws-iac-mcp": {
      "enabled": false,
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-v",
        "/home/javi/.aws:/app/.aws:U",
        "-v",
        "/home/javi/javier-campa-dotfiles/dot-aws:/app/javier-campa-dotfiles/dot-aws:U",
        "-e",
        "AWS_PROFILE=javier",
        "public.ecr.aws/awslabs-mcp/awslabs/aws-iac-mcp-server:latest",
        "--readonly"
      ],
      "environment": {}
    },
    "aws-knowledge-mcp": {
      "enabled": false,
      "type": "remote",
      "url" :"https://knowledge-mcp.global.api.aws"
    },
    "aws-pricing-mcp": {
      "enabled": false,
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-v",
        "/home/javi/.aws:/app/.aws:U",
        "-v",
        "/home/javi/javier-campa-dotfiles/dot-aws:/app/javier-campa-dotfiles/dot-aws:U",
        "-e",
        "AWS_PROFILE=javier",
        "public.ecr.aws/awslabs-mcp/awslabs/aws-pricing-mcp-server:latest"
      ],
      "environment": {}
    },
    "context7": {
      "enabled": false,
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT=stdio",
        "mcp/context7"
      ],
      "environment": {}
    }
  }
}
